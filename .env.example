# CaptureOS v3 — environment configuration template
#
# Copy this file to `.env` and fill in real values for your environment.
# `.env` is gitignored and MUST NOT be committed. Every variable below maps
# to a field on `Settings` in `config/settings.py` (pydantic-settings reads
# names case-insensitively). Values shown are non-sensitive placeholders.

# --- API -------------------------------------------------------------------
# Host/port the API binds to, and the externally reachable backend URL.
# Override BACKEND_URL with the deployed host in production.
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_URL=http://localhost:8000

# --- Storage ---------------------------------------------------------------
# STORAGE_MODE selects where generated artifacts are stored: "local" | "s3" | "r2".
# Leave the S3/R2 values blank when STORAGE_MODE=local.
STORAGE_MODE=local
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
R2_ACCOUNT_ID=
R2_ENDPOINT=

# --- IA / AI keys ----------------------------------------------------------
# API keys for the AI pipeline and vector search. Keep these secret.
GOOGLE_API_KEY=
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# --- Worker / Redis --------------------------------------------------------
# Redis connection string used by the background worker / task queue.
REDIS_URL=redis://localhost:6379

# --- Auth (Supabase / JWT) -------------------------------------------------
# Production auth is backed by Supabase + a JWT secret. Change JWT_SECRET
# away from the dev default before deploying.
SUPABASE_URL=
SUPABASE_ANON_KEY=
JWT_SECRET=dev-secret-change-in-prod

# --- CORS / Extension ------------------------------------------------------
# Comma-separated allow-list of origins permitted to call the API. Include the
# extension origin (chrome-extension://<EXTENSION_ID>) and the deployed backend
# host. Never combine a wildcard "*" with credentialed access.
ALLOWED_ORIGINS=http://localhost:8000
# The published Chrome extension ID, used to build the chrome-extension:// origin.
EXTENSION_ID=
