{
  "manifest_version": 3,
  "name": "Capture OS",
  "version": "1.0.11",
  "description": "Gravação inteligente e criação de tutoriais na velocidade do pensamento.",
  "permissions": [
    "desktopCapture",
    "activeTab",
    "storage",
    "unlimitedStorage",
    "tabs",
    "scripting",
    "offscreen",
    "tabCapture",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://api.captureos.fly.dev/*",
    "https://api.nomadelabs.com.br/*",
    "http://api.nomadelabs.com.br:8000/*",
    "http://143.95.218.215:8000/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts/shield.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts/radar_v3.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Iniciar Captura",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
