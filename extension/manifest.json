{
  "manifest_version": 3,
  "name": "Capture OS v3 - Frictionless Recorder",
  "version": "1.0",
  "description": "Ferramenta de captura sem atrito para gerar roteiros corporativos.",
  "permissions": [
    "desktopCapture",
    "activeTab",
    "storage",
    "unlimitedStorage",
    "tabs",
    "scripting",
    "offscreen",
    "tabCapture"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts/shield.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts/radar_v3.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Iniciar Captura",
    "default_popup": "popup.html"
  }
}
